---
import Base from '../layouts/Base.astro';
import PaperCard from '../components/PaperCard.astro';
import GameCard from '../components/GameCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

// 收集所有内容，按时间倒序
const papers = (await getCollection('papers'))
  .sort((a, b) => b.data.year - a.data.year || +b.data.date - +a.data.date);

const games = (await getCollection('games'))
  .sort((a, b) => b.data.year - a.data.year || +b.data.date - +a.data.date);

const projects = (await getCollection('projects'))
  .sort((a, b) => +b.data.date - +a.data.date);
---

<Base title="Yang Ziyue">
  {/* ============ 区块 1：个人简介与照片 ============ */}
  <section id="about" class="hero">
    <img src="/images/avatar.png" alt="Yang Ziyue" class="avatar" />
    <h1>Yang Ziyue</h1>
    <p class="subtitle">
      Master Student @ SJTU · AI Agents · Indie Game Developer
    </p>
    <p class="bio">
      I am a master's student in the School of Computer Science at Shanghai Jiao Tong University. I'm studying at <a href="http://speechlab.sjtu.edu.cn/" target="_blank" rel="noopener">X-lance lab</a> under the guidance of Professcor ChenLu
    </p>
    <p class="bio">
      Welcome to my personal sites. Here includes <a href="#papers">Research Papers</a>,
      <a href="#games">Game Made</a>, and participated <a href="#projects">Open-Source Repositories</a>.
      My research interests lie in scientific research agents and reinforcement learning.
      Additionally, I am an entry-level game developer who has undertaken program and design roles for several independent games.
    </p>

    {/* 个性签名（书法体）—— 直接分区，不加「个人签名：」之类的标签 */}
    <blockquote class="signature">
      the orgiastic future that year by year recedes before us. it eluded us then,<br />
      but that's no matter — tomorrow we will run faster, stretch out arms farther…<br />
      and one fine morning — so we beat on, boats against the current,<br />
      borne back ceaselessly into the past. — <em>The Great Gatsby</em>
    </blockquote>

    <div class="links">
      <a href="mailto:1369700255@qq.com">✉️ Email</a>
      <a href="https://github.com/Drunk-mooon" target="_blank" rel="noopener">🐙 GitHub</a>
      <a href="https://twitter.com/DrunkMooon_" target="_blank" rel="noopener">🐦 Twitter</a>
    </div>
  </section>

  <hr class="divider" />

  {/* ============ 区块 2：论文 ============ */}
  <section id="papers">
    <h2>📄 Papers</h2>
    <p class="lead">Arrange in descending order of publication year.</p>

    {papers.length === 0 ? (
      <p class="empty">还没有论文。在 <code>src/content/papers/</code> 下新建 <code>.md</code> 文件即可添加。</p>
    ) : (
      <ul class="cards">
        {papers.map(p => (
          <PaperCard
            title={p.data.title}
            authors={p.data.authors}
            venue={p.data.venue}
            year={p.data.year}
            pdf={p.data.pdf}
            code={p.data.code}
            project={p.data.project}
            poster={p.data.poster}
            tldr={p.data.tldr}
            abstract={p.data.abstract}
          />
        ))}
      </ul>
    )}
  </section>

  <hr class="divider" />

  {/* ============ 区块 3：游戏 ============ */}
  <section id="games">
    <h2>🎮 Games</h2>
    <p class="lead">Game demos that I have participated in or independently produced.</p>

    {games.length === 0 ? (
      <p class="empty">还没有游戏。在 <code>src/content/games/</code> 下新建 <code>.md</code> 文件即可添加。</p>
    ) : (
      <ul class="cards">
        {games.map(g => (
          <GameCard
            title={g.data.title}
            cover={g.data.cover}
            platform={g.data.platform}
            year={g.data.year}
            link={g.data.link}
            video={g.data.video}
            description={g.data.description}
            role={g.data.role}
          />
        ))}
      </ul>
    )}
  </section>

  <hr class="divider" />

  {/* ============ 区块 4：开源项目 ============ */}
  <section id="projects">
    <h2>🛠 Open Source Projects</h2>
    <p class="lead">The open-source projects that I maintain or primarily participate in on GitHub.</p>

    {projects.length === 0 ? (
      <p class="empty">还没有项目。在 <code>src/content/projects/</code> 下新建 <code>.md</code> 文件即可添加。</p>
    ) : (
      <ul class="cards">
        {projects.map(p => (
          <ProjectCard
            title={p.data.title}
            description={p.data.description}
            github={p.data.github}
            tags={p.data.tags}
            year={p.data.date.getFullYear()}
          />
        ))}
      </ul>
    )}
  </section>

  <hr class="divider" />

  {/* ============ 区块 5：爱好（最末，量级最小） ============ */}
  <section id="hobbies" class="hobbies">
    <h2>🌿 Hobbies</h2>
    <p class="hobby-list">
      🎮 PC GAME · 🎸 Guitar · ✨ ACG · 🏀 Basketball &amp; NBA · 📚 Reading
    </p>
  </section>
</Base>

<style>
  .hero {
    text-align: center;
    padding: 2.5rem 0 2rem;
  }
  .avatar {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--color-border);
  }
  .hero h1 {
    margin: 1rem 0 0.25rem;
    font-size: 2rem;
  }
  .subtitle {
    color: var(--color-muted);
    margin: 0 0 1rem;
  }
  .bio {
    max-width: 620px;
    margin: 0 auto 0.75rem;
    color: var(--color-fg);
  }
  .links {
    margin-top: 1.25rem;
  }
  .links a {
    margin: 0 0.4rem;
    display: inline-block;
  }

  section { scroll-margin-top: 70px; }

  .lead { color: var(--color-muted); margin-top: -0.5rem; }

  .divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3rem 0;
  }

  .empty {
    background: var(--color-card);
    border: 1px dashed var(--color-border);
    padding: 1.5rem;
    border-radius: 6px;
    color: var(--color-muted);
  }

  /* 个性签名：居中的书法体短句 */
  .signature {
    font-family: var(--font-calligraphy);
    font-size: 1.05rem;
    line-height: 1.9;
    max-width: 640px;
    margin: 2rem auto 1.6rem;
    padding: 1.4rem 1.25rem 1.6rem;
    color: var(--color-fg);
    text-align: center;
    font-style: normal;          /* 书法体自身带斜势，再 italic 会被外力破坏 */
    position: relative;
    quotes: none;
    border: 0;
  }
  .signature::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 56px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
  }
  .signature::after {
    content: "";
    display: block;
    width: 6px;
    height: 6px;
    margin: 0.85rem auto 0;
    border-radius: 50%;
    background: var(--color-accent);
  }

  /* 爱好区域：量级明显小一档，纯一行带图标，不做卡片 */
  .hobbies {
    text-align: center;
    margin: 0.5rem 0 1rem;
  }
  .hobbies h2 {
    font-size: 1.1rem;
    color: var(--color-muted);
    font-weight: 600;
    letter-spacing: 0.4px;
    margin: 0 0 0.65rem;
  }
  .hobby-list {
    font-size: 0.95rem;
    color: var(--color-fg);
    margin: 0;
    line-height: 1.9;
  }
  .hobby-list {
    word-spacing: 0.25em;
  }
</style>