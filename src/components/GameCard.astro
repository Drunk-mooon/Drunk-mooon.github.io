---
interface Props {
  title: string;
  cover: string;
  platform: string;
  year: number;
  link?: string;
  video?: string;
  description: string;
  role?: string;
}

const { title, cover, platform, year, link, video, description, role } = Astro.props;

// 把链接显示成纯净的地址（去掉 https:// 和末尾斜杠），便于一眼看清指向哪里
const displayLink = link?.replace(/^https?:\/\//, '').replace(/\/$/, '');
const displayVideo = video?.replace(/^https?:\/\//, '').replace(/\/$/, '');
---

<li class="card game-card">
  <img src={cover} alt={`${title} cover`} class="cover" />
  <div class="info">
    <h3>{title}</h3>
    <p class="meta">{platform} · {year}{role && ` · ${role}`}</p>
    <p>{description}</p>

    {/* link 和 video 放在同一个 .links 段落里，自动用 anchor 间距分隔 */}
    {(link || video) && (
      <p class="links">
        {link && <a href={link} target="_blank" rel="noopener">{displayLink}</a>}
        {video && <a href={video} target="_blank" rel="noopener">🎬 {displayVideo}</a>}
      </p>
    )}
  </div>
</li>

<style>
  .game-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .cover {
    width: 120px;
    height: 120px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
    background: var(--color-border);
  }
  .info { flex: 1; min-width: 0; }
  .info h3 { margin-top: 0; }
  @media (max-width: 520px) {
    .game-card { flex-direction: column; }
    .cover { width: 100%; height: 180px; }
  }
</style>
