---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <span>© {year} Yang Ziyue</span>
    <span class="links">
      <a href="mailto:YOUR_EMAIL@example.com">Email</a> ·
      <a href="https://github.com/YOUR_GITHUB_USERNAME" target="_blank" rel="noopener">GitHub</a> ·
      <a href="https://scholar.google.com/citations?user=YOUR_SCHOLAR_ID" target="_blank" rel="noopener">Scholar</a>
    </span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    margin-top: 3rem;
    padding: 1.25rem 1.25rem;
    color: var(--color-muted);
    font-size: 0.85rem;
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .links a { color: var(--color-muted); }
  .links a:hover { color: var(--color-accent); }
</style>