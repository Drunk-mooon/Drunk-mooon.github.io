---
interface Props {
  title: string;
  description?: string;
  github: string;
  tags?: string[];
  year?: number;
}

const { title, description, github, tags = [], year } = Astro.props;

// 从 GitHub URL 里抽取仓库名用于显示，比如：
//   https://github.com/Drunk-mooon/foo  →  foo
const repoName = github.split('/').filter(Boolean).slice(-1)[0];
---

<li class="card">
  <h3>
    <a href={github} target="_blank" rel="noopener">{title}</a>
  </h3>

  <p class="meta">
    <a href={github} target="_blank" rel="noopener" class="repo-link">
      github.com/.../{repoName}
    </a>
    {year ? ` · ${year}` : null}
  </p>

  {description ? (
    <p>{description}</p>
  ) : null}

  {tags.length > 0 ? (
    <p class="tags">
      {tags.map((t) => (
        <span class="tag">{t}</span>
      ))}
    </p>
  ) : null}
</li>

<style>
  .card h3 { margin-bottom: 0.25rem; }
  .repo-link { font-family: var(--font-mono); font-size: 0.85rem; }
</style>
